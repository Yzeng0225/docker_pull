{
  "name": "RAGFlow Pull Helper",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-22.04",
  "hostRequirements": {
    "memory": "8gb",
    "cpus": 4,
    "diskSize": "64gb"
  },
  "runArgs": [
    "--shm-size=2g"
  ],
  "customizations": {
    "vscode": {
      "extensions": ["ms-azuretools.vscode-docker"]
    }
  },
  "remoteUser": "root"
}
